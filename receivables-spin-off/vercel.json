{
  "buildCommand": "prisma generate && prisma db push --accept-data-loss && next build && node scripts/copy-pdfkit-fonts.js",
  "crons": [
    {
      "path": "/api/cron/check-outstanding-invoices",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/compensation-calculate",
      "schedule": "0 10 1 * *"
    },
    {
      "path": "/api/cron/fringe-benefits",
      "schedule": "0 8 * * *"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "includeFiles": "node_modules/pdfkit/js/data/**"
    }
  }
}
